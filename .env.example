# Live web retrieval (demo gate)
TAVILY_API_KEY=

# Chroma persistent store (vector indices)
CHROMA_PERSIST_DIR=./data/chroma

# App data (traces, outcomes, exports)
FORESIGHT_DATA_DIR=./data
FORESIGHT_USER_ID=demo_user

# LLM + embeddings via OpenAI API (used through LlamaIndex wrappers)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: Azure OpenAI or proxy (leave unset for api.openai.com)
# OPENAI_API_BASE=https://your-resource.openai.azure.com
